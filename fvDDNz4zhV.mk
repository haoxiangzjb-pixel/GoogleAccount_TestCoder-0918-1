# Makefile for compiling a C program\n\n# Compiler\nCC = gcc\n\n# Compiler flags\nCFLAGS = -Wall -Wextra -std=c99\n\n# Target executable\nTARGET = hello\n\n# Source file\nSOURCE = hello.c\n\n# Default target\nall: $(TARGET)\n\n# Rule to compile the program\n$(TARGET): $(SOURCE)\n\t$(CC) $(CFLAGS) -o $(TARGET) $(SOURCE)\n\n# Clean rule\nclean:\n\trm -f $(TARGET)\n\n.PHONY: all clean
