# Makefile for C++ project

# Compiler and flags
CXX = g++
CXXFLAGS = -std=c++17 -Wall -Wextra -g
INCLUDES = -Iinclude

# Directories
SRC_DIR = src
INC_DIR = include
TEST_DIR = tests
BUILD_DIR = build
BIN_DIR = $(BUILD_DIR)/bin

# Default target
.PHONY: all
all: build

# Build target - creates the main executable
.PHONY: build
build:
	@echo "Building project..."
	@mkdir -p $(BIN_DIR)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $(BIN_DIR)/main $(SRC_DIR)/*.cpp
	@echo "Build complete!"

# Test target - compiles and runs tests
.PHONY: test
test:
	@echo "Running tests..."
	@mkdir -p $(BIN_DIR)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $(BIN_DIR)/tests $(TEST_DIR)/*.cpp $(SRC_DIR)/*.cpp
	$(BIN_DIR)/tests
	@echo "Tests completed!"

# Clean target - removes build artifacts
.PHONY: clean
clean:
	@echo "Cleaning build artifacts..."
	@rm -rf $(BUILD_DIR)
	@echo "Clean complete!"

# Help target - shows available targets
.PHONY: help
help:
	@echo "Available targets:"
	@echo "  all     - Build the project (default)"
	@echo "  build   - Build the project"
	@echo "  test    - Run tests"
	@echo "  clean   - Remove build artifacts"
	@echo "  help    - Show this help message"