# Randomly named Makefile for C++ project
# Created for demonstrating build, test, and clean targets

# Compiler and flags
CXX = g++
CXXFLAGS = -Wall -Wextra -std=c++17 -g
INCLUDES = -I./include
LIBS = 

# Directories
SRCDIR = src
INCDIR = include
OBJDIR = obj
BINDIR = bin

# Source files (excluding test files)
SOURCES = $(filter-out $(SRCDIR)/test_main.cpp,$(wildcard $(SRCDIR)/*.cpp))
OBJECTS = $(SOURCES:$(SRCDIR)/%.cpp=$(OBJDIR)/%.o)

# Test source files
TEST_SOURCES = $(SRCDIR)/test_main.cpp
TEST_OBJECTS = $(TEST_SOURCES:$(SRCDIR)/%.cpp=$(OBJDIR)/%.o)

# Target executables
TARGET = $(BINDIR)/app
TEST_TARGET = $(BINDIR)/test

# Default target
.PHONY: all
all: build

# Build target - creates the main application
.PHONY: build
build: $(TARGET)

$(TARGET): $(OBJECTS) | $(BINDIR)
	$(CXX) $(OBJECTS) -o $@ $(LIBS)
	@echo "Build completed! Executable created at $(TARGET)"

# Test target - creates and runs the test application
.PHONY: test
test: $(TEST_TARGET)
	@echo "Running tests..."
	./$(TEST_TARGET)

$(TEST_TARGET): $(TEST_OBJECTS) $(filter-out $(OBJDIR)/main.o,$(OBJECTS)) | $(BINDIR)
	$(CXX) $^ -o $@ $(LIBS)
	@echo "Test executable created at $(TEST_TARGET)"

# Compile source files to object files
$(OBJDIR)/%.o: $(SRCDIR)/%.cpp | $(OBJDIR)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -c $< -o $@

# Create directories if they don't exist
$(OBJDIR) $(BINDIR):
	mkdir -p $@

# Clean target - removes generated files
.PHONY: clean
clean:
	rm -rf $(OBJDIR) $(BINDIR)
	@echo "Clean completed! Removed object files and executables."

# Help target
.PHONY: help
help:
	@echo "Available targets:"
	@echo "  all     - Build the main application (default)"
	@echo "  build   - Build the main application"
	@echo "  test    - Build and run tests"
	@echo "  clean   - Remove generated files"
	@echo "  help    - Show this help message"