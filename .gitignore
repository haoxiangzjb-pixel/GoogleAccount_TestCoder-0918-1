```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
.coverage

# MyPy cache
.mypy_cache/

# Pytest cache
.pytest_cache/

# Distribution files
dist/
build/
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Node modules (if any)
node_modules/

# Gradle
.gradle/
target/

# Temporary files
*.tmp
*~
.DS_Store
Thumbs.db
```