```
# Generated .gitignore for TypeScript project

# TypeScript build output
*.js
*.js.map
*.ts.buildinfo

# Dependencies
node_modules/

# Environment variables
.env
.env.local
*.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Coverage
coverage/
htmlcov/
*.coverage

# Temporary files
*.tmp
*.temp

# OS generated files
.DS_Store
Thumbs.db

# Build directories
dist/
build/
target/
out/
lib/

# Package manager caches
.npm/
.yarn/
.pnpm/
.bazel/
.nyc_output/

# Testing
*.spec.ts
*.test.ts

# Compression files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
